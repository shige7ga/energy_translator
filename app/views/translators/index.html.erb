<div class="container-xxl p-0 p-md-3">
  <div class="app-shell">
    <header class="app-header px-3 px-md-5 py-3">
      <div class="d-flex align-items-center justify-content-between gap-3">
        <div class="d-flex align-items-center gap-3">
          <div class="app-logo" aria-hidden="true">🔥</div>
          <h1 class="app-title h2 mb-0">エネルギー翻訳機</h1>
        </div>
      </div>
    </header>

    <main class="main-content px-3 px-md-5 py-3 py-md-4">
      <section class="text-center mb-3 mb-md-4">
        <h2 class="hero-title mb-0">
          <span class="accent">エネルギー</span>🔥を、直感的な表現へ
        </h2>
        <div class="hero-underline"></div>
      </section>

      <section class="row mb-4">
        <div class="col-12 col-lg-9 mx-auto">
          <div class="input-card p-4 mb-4">
            <%= form_with model: @form, url: create_path do |f| %>
              <div class="mb-4">
                <%= f.label :input, 'エネルギー量を入力', class: 'section-label mb-3' %>
                <div class="d-flex gap-3 align-items-center">
                  <%= f.number_field :input, class: 'form-control energy-input', placeholder: '例: 500' %>
                  <div>
                    <%= f.collection_select :energy_unit_id,
                                            @energy_units,
                                            :id,
                                            :name,
                                            {},
                                            { class: 'form-select energy-select' }
                                            %>
                  </div>
                </div>
                <div id="input_error"></div>
              </div>
              <div class="mb-4">
                <%= f.label :conversion_id, '翻訳先を選択', class: 'section-label mb-3' %>
                <%= f.collection_select :conversion_id,
                                        @conversions,
                                        :id,
                                        :name,
                                        {},
                                        { class: 'form-select energy-select' } %>
                <div id="conversion_id_error"></div>
              </div>
              <%= f.submit '⟳ 翻訳する', class: 'btn translate-btn w-100' %>
            </div>
            <% end %>

            <div id="result_area"></div>

          </div>
        </div>
      </section>
    </main>
  </div>
</div>
